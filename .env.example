# OpenAI API Key — обязательно для работы системы
OPENAI_API_KEY=sk-your-key-here

# Модель GPT (по умолчанию gpt-4o-mini, замените на gpt-5-mini когда станет доступна)
OPENAI_MODEL=gpt-4o-mini

# Email для дайджеста преподавателя (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
DIGEST_RECIPIENT=professor@hse.ru
